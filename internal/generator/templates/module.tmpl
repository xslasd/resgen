	{{- range .Args}}
	{{- if and .IsScalar (or (eq .Source "Path") (eq .Source "Query") (eq .Source "Header"))}}
	{{- $extractFunc := "GetQuery" -}}
	{{- if eq .Source "Path"}}{{$extractFunc = "GetPath"}}{{end}}
	{{- if eq .Source "Header"}}{{$extractFunc = "GetHeader"}}{{end}}
	if val := request.{{$extractFunc}}("{{.Name}}"); val != "" {
		var tmp {{.ScalarModel}}
		if err := tmp.FromParam(request.Native(), val); err != nil { return err }
		{{- if HasPrefix .GoType "*" }}
		targetVal := {{slice .GoType 1}}(tmp)
		input.{{.GoName}} = &targetVal
		{{- else}}
		input.{{.GoName}} = {{.GoType}}(tmp)
		{{- end}}
	}
	{{- else if not .IsScalar}}
	{{- if or (eq .Source "Path") (eq .Source "Query") (eq .Source "Header")}}
	{{- $extractFunc := "GetQuery" -}}
	{{- if eq .Source "Path"}}{{$extractFunc = "GetPath"}}{{end}}
	{{- if eq .Source "Header"}}{{$extractFunc = "GetHeader"}}{{end}}
	if val := request.{{$extractFunc}}("{{.Name}}"); val != "" {
		{{ParseParam (printf "input.%s" .GoName) "val" .GoType}}
	}
	{{- end}}
	{{- end}}
	{{- end}}
	{{- else}}
	{{- if eq .Method "GET"}}
	{{- range (index .Args 0).RefModel.Fields}}
	{{- if .IsScalar}}
	if val := request.GetQuery("{{.JSONName}}"); val != "" {
		var tmp {{.ScalarModel}}
		if err := tmp.FromParam(request.Native(), val); err != nil { return err }
		{{- if HasPrefix .GoType "*" }}
		targetVal := {{slice .GoType 1}}(tmp)
		input.{{.Name}} = &targetVal
		{{- else}}
		input.{{.Name}} = {{.GoType}}(tmp)
		{{- end}}
	}
	{{- else}}
	if val := request.GetQuery("{{.JSONName}}"); val != "" {
		{{ParseParam (printf "input.%s" .Name) "val" .GoType}}
	}
	{{- end}}
	{{- end}}
	{{- end}}
    {{- end}}
    return nil
}
{{end}}

{{- if and .HasInput .HasValidation (not .CustomValidate)}}
// validate{{.Name}} 参数验证逻辑
func (e *{{$.Module.Name}}Executor[T, C]) validate{{.Name}}(ctx T, input *{{.InputName}}) error {
	{{- if .IsArgsWrapped}}
	// Pass 1: Required validations for top-level arguments and their fields
	{{- range .Args}}
	{{- $arg := .}}
	{{- range .Validators}}{{if eq .Name "Required"}}
	if err := e.v.{{.Name}}(ctx, "{{$arg.Name}}", input.{{$arg.GoName}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	{{- end}}{{end}}
	{{- if .RefModel}}{{range .RefModel.Fields}}{{$field := .}}{{- range .Validators}}{{if eq .Name "Required"}}
	if input.{{$arg.GoName}} != nil {
		if err := e.v.{{.Name}}(ctx, "{{$arg.Name}}.{{$field.JSONName}}", input.{{$arg.GoName}}.{{$field.Name}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	}
	{{- end}}{{end}}{{end}}{{end}}
	{{- end}}

	// Pass 2: Other validations
	{{- range .Args}}
	{{- $arg := .}}
	{{- range .Validators}}{{if ne .Name "Required"}}
	{{- if HasPrefix $arg.Type "*"}}
	if input.{{$arg.GoName}} != nil {
		if err := e.v.{{.Name}}(ctx, "{{$arg.Name}}", *input.{{$arg.GoName}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	}
	{{- else}}
	if err := e.v.{{.Name}}(ctx, "{{$arg.Name}}", input.{{$arg.GoName}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	{{- end}}
	{{- end}}{{end}}
	{{- if .RefModel}}{{range .RefModel.Fields}}{{$field := .}}{{- range .Validators}}{{if ne .Name "Required"}}
	if input.{{$arg.GoName}} != nil {
		{{- if HasPrefix $field.Type "*"}}
		if input.{{$arg.GoName}}.{{$field.Name}} != nil {
			if err := e.v.{{.Name}}(ctx, "{{$arg.Name}}.{{$field.JSONName}}", *input.{{$arg.GoName}}.{{$field.Name}} {{range .Args}}, {{Replace .GoValue "input." (printf "input.%s." $arg.GoName)}}{{end}}); err != nil { return err }
		}
		{{- else}}
		if err := e.v.{{.Name}}(ctx, "{{$arg.Name}}.{{$field.JSONName}}", input.{{$arg.GoName}}.{{$field.Name}} {{range .Args}}, {{Replace .GoValue "input." (printf "input.%s." $arg.GoName)}}{{end}}); err != nil { return err }
		{{- end}}
	}
	{{- end}}{{end}}{{end}}{{end}}
	{{- end}}
	{{- else}}
	{{- $inputModel := (index .Args 0).RefModel}}
	// Pass 1: Required validations
	{{- range $inputModel.Fields}}
	{{- $field := .}}
	{{- range .Validators}}{{if eq .Name "Required"}}
	if err := e.v.{{.Name}}(ctx, "{{$field.JSONName}}", input.{{$field.Name}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	{{- end}}{{end}}
	{{- if .RefModel}}{{range .RefModel.Fields}}{{$subField := .}}{{- range .Validators}}{{if eq .Name "Required"}}
	if err := e.v.{{.Name}}(ctx, "{{$field.JSONName}}.{{$subField.JSONName}}", input.{{$field.Name}}.{{$subField.Name}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	{{- end}}{{end}}{{end}}{{end}}
	{{- end}}

	// Pass 2: Other validations
	{{- range $inputModel.Fields}}
	{{- $field := .}}
	{{- range .Validators}}{{if ne .Name "Required"}}
	{{- if HasPrefix $field.Type "*"}}
	if input.{{$field.Name}} != nil {
		if err := e.v.{{.Name}}(ctx, "{{$field.JSONName}}", *input.{{$field.Name}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	}
	{{- else}}
	if err := e.v.{{.Name}}(ctx, "{{$field.JSONName}}", input.{{$field.Name}} {{range .Args}}, {{.GoValue}}{{end}}); err != nil { return err }
	{{- end}}
	{{- end}}{{end}}
	{{- if .RefModel}}{{range .RefModel.Fields}}{{$subField := .}}{{- range .Validators}}{{if ne .Name "Required"}}
	{{- if HasPrefix $subField.Type "*"}}
	if input.{{$field.Name}}.{{$subField.Name}} != nil {
		if err := e.v.{{.Name}}(ctx, "{{$field.JSONName}}.{{$subField.JSONName}}", *input.{{$field.Name}}.{{$subField.Name}} {{range .Args}}, {{Replace .GoValue "input." (printf "input.%s." $field.Name)}}{{end}}); err != nil { return err }
	}
	{{- else}}
	if err := e.v.{{.Name}}(ctx, "{{$field.JSONName}}.{{$subField.JSONName}}", input.{{$field.Name}}.{{$subField.Name}} {{range .Args}}, {{Replace .GoValue "input." (printf "input.%s." $field.Name)}}{{end}}); err != nil { return err }
	{{- end}}
	{{- end}}{{end}}{{end}}{{end}}
	{{- end}}
	{{- end}}
	return nil
}
