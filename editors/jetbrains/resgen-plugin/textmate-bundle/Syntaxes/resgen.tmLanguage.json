{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Resgen",
    "scopeName": "source.resgen",
    "fileTypes": ["res", "resgen"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#builtin-types" },
        { "include": "#constants" },
        { "include": "#meta-attributes" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#decorators" },
        { "include": "#fields" },
        { "include": "#type-references" },
        { "include": "#identifiers" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.number-sign.resgen", "match": "#.*$" }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "storage.type.resgen",
                    "match": "\\b(module|type|input|wrap|group|decorator|validator|scalar)\\b"
                },
                {
                    "name": "keyword.control.resgen",
                    "match": "\\b(GET|POST|PUT|DELETE|PATCH|get|post|put|delete|patch)\\b"
                }
            ]
        },
        "builtin-types": {
            "patterns": [
                {
                    "name": "support.type.builtin.resgen",
                    "match": "\\b(String|Int|Float|Boolean|Time|File|Any|Field)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.resgen",
                    "match": "\\b(none|json|form|multipart|xml|text)\\b"
                }
            ]
        },
        "meta-attributes": {
            "patterns": [
                {
                    "match": "\\b(wrap|state|ctype|etype)\\b\\s*=",
                    "captures": {
                        "1": {
                            "name": "support.constant.meta.resgen"
                        }
                    }
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.resgen",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                { "name": "constant.character.escape.resgen", "match": "\\\\." }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.resgen", "match": "\\b\\d+\\b" }
            ]
        },
        "decorators": {
            "patterns": [
                { "name": "entity.name.function.decorator.resgen", "match": "@[a-zA-Z_][a-zA-Z0-9_]*" }
            ]
        },
        "fields": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
                    "captures": { "1": { "name": "entity.name.tag.resgen" } }
                }
            ]
        },
        "type-references": {
            "patterns": [
                {
                    "match": "(:|\\[|,)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": { "2": { "name": "variable.other.resgen" } }
                }
            ]
        },
        "identifiers": {
            "patterns": [
                { "name": "variable.other.resgen", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b" }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.resgen",
                    "match": "=>|:|!|\\[|\\]|\\{|\\}|<|>|\\(|\\)|,"
                }
            ]
        }
    }
}
